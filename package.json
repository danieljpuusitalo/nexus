{
  "name": "nexus-crm",
  "productName": "Nexus",
  "version": "1.0.0",
  "description": "Personal CRM — built for people who take relationships seriously",
  "author": "Nexus CRM",
  "homepage": "https://github.com/danieljpuusitalo/nexus",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-vite build && electron-builder --win",
    "build:web": "vite build --config vite.web.config.ts",
    "dev:web": "vite dev --config vite.web.config.ts --port 5174",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "@types/qrcode": "^1.5.6",
    "better-sqlite3": "^12.8.0",
    "d3": "^7.9.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/d3": "^7.4.3",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^40.8.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.nexuscrm.app",
    "productName": "Nexus",
    "copyright": "Copyright © 2026 Nexus CRM",
    "icon": "resources/icon.ico",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Nexus"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "danieljpuusitalo",
      "repo": "nexus"
    }
  }
}
